# WebSocket 连接升级配置
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# 后端服务 upstream 配置
upstream backend {
    server 127.0.0.1:4000;  # 指向宿主机上的后端服务
    keepalive 64;  # 保持连接以提高性能
}

# 前端服务 upstream 配置
upstream frontend {
    server 127.0.0.1:3000;  # 指向宿主机上的前端服务
    keepalive 64;
}

# 主服务器配置
server {
    listen 1180 default_server;  # 确保是默认服务器
    listen [::]:1180 default_server;  # IPv6 支持
    server_name _;  # 通配符匹配所有域名
    proxy_http_version 1.1;

    # 增加超时设置以处理长时间运行的请求
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 180s;

    # 增加缓冲区大小以提高性能
    proxy_buffers 16 16k;
    proxy_buffer_size 32k;

    # 关闭访问日志以提高性能（可选）
    # access_log off;
    # error_log /var/log/nginx/blockscout_error.log error;

    # 后端 API 和 WebSocket 路由
    location ~ ^/(api(?!-docs$)|socket|sitemap.xml|auth/auth0|auth/auth0/callback|auth/logout) {
        proxy_pass            http://backend;
        proxy_http_version    1.1;
        proxy_set_header      Host $host;
        proxy_set_header      X-Real-IP $remote_addr;
        proxy_set_header      X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto $scheme;
        proxy_set_header      Upgrade $http_upgrade;
        proxy_set_header      Connection $connection_upgrade;
        proxy_cache_bypass    $http_upgrade;
    }

    # 前端静态资源路由
    location / {
        proxy_pass            http://frontend;
        proxy_http_version    1.1;
        proxy_set_header      Host $host;
        proxy_set_header      X-Real-IP $remote_addr;
        proxy_set_header      X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto $scheme;
        proxy_set_header      Upgrade $http_upgrade;
        proxy_set_header      Connection $connection_upgrade;
        proxy_cache_bypass    $http_upgrade;
    }

    # 增加健康检查端点
    location /health {
        stub_status on;
        access_log off;
        allow 127.0.0.1;
        deny all;
    }

    # 错误页面配置
    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
